    .level-row.l3 .level-tools { color: #6aff8a; }
    .level-row.l4 {
        background: rgba(74, 158, 255, 0.04);
        border-left: 3px solid #4a9eff;
    }
    .level-row.l4 .level-badge { color: #4a9eff; }
    .level-row.l4 .level-tools { color: #4a9eff; }

    @media (max-width: 640px) {
        .platform-items { grid-template-columns: 1fr; }
        .summary-table td:first-child { width: auto; }
        .level-row { grid-template-columns: 45px 1fr; }
    }
</style>
