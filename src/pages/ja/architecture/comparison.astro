    }
    .level-row.l1 {
        background: rgba(255, 106, 106, 0.03);
    }
    .level-row.l1 .level-badge { color: #ff6a6a; }
    .level-row.l1 .level-tools { color: #ff6a6a; }
    .level-row.l2 {
        background: rgba(255, 184, 106, 0.03);
    }
    .level-row.l2 .level-badge { color: #ffb86a; }
    .level-row.l2 .level-tools { color: #ffb86a; }
    .level-row.l3 {
        background: rgba(106, 255, 138, 0.04);
        border-left: 3px solid #6aff8a;
    }
