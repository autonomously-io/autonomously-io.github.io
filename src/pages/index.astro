---
import Base from "../layouts/Base.astro";
---

<Base title="a10y - Autonomously">
    <!-- Hero -->
    <div class="hero">
        <div class="hero-inner">
            <img src="/logo.svg" alt="a10y" class="logo" />
            <p class="expand">Autonomously</p>
            <p class="tagline">Penetrate. Understand. Restore.<br>Autonomously understands and restores your network.</p>
            <p class="sub">Statistical AI + LLM — the right technique at every phase.</p>
            <div class="links">
                <a href="/why">Why Autonomously?</a>
                <a href="/landscape">Landscape</a>
                <a href="/ooda">OODA × AI</a>
                <a href="https://github.com/autonomously-io">GitHub</a>
            </div>
            <div class="github-star">
                <a class="github-button" href="https://github.com/autonomously-io/autonomously-io.github.io" data-icon="octicon-star" data-size="large" data-show-count="true" aria-label="Star autonomously-io/autonomously-io.github.io on GitHub">Star</a>
            </div>
            <script async defer src="https://buttons.github.io/buttons.js"></script>
        </div>
    </div>

    <!-- What is a10y -->
    <section class="section">
        <div class="container">
            <h2>What is a10y?</h2>
            <p>a10y is a multi-source correlation engine that fuses signals from across your network — logs, metrics, traces, alerts, topology — and turns them into <span class="highlight">causal understanding</span>. It doesn't just detect problems; it understands <em>why</em> they happen and closes the loop by acting and verifying autonomously.</p>
        </div>
    </section>

    <!-- Two Pillars -->
    <section class="section alt">
        <div class="container">
            <h2>Two Pillars</h2>
            <div class="pillars">
                <div class="pillar">
                    <h3>Understandability</h3>
                    <p>Beyond observability. Correlate multi-source signals across layers and vendors to uncover causal relationships and pinpoint root causes — not just symptoms.</p>
                </div>
                <div class="pillar">
                    <h3>Closed Loop Automation</h3>
                    <p>Observe → Correlate → Understand → Act → Verify. The system doesn't stop at insight — it takes action and confirms the outcome, autonomously.</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Dual AI -->
    <section class="section">
        <div class="container">
            <h2>Dual AI Approach</h2>
            <div class="pillars">
                <div class="pillar">
                    <h3>Statistical AI &amp; ML</h3>
                    <p>Time-series anomaly detection, topology-aware correlation, predictive failure models. High-volume structured signals at speed — no hallucination risk.</p>
                </div>
                <div class="pillar">
                    <h3>Large Language Models</h3>
                    <p>Causal reasoning over unstructured data, natural language interaction, RAG-powered runbook retrieval. Context and judgment where they matter most.</p>
                </div>
            </div>
            <p class="center-note">Statistical models detect <em>that</em> something is wrong. LLMs reason about <em>why</em> and <em>what to do</em>.</p>
        </div>
    </section>

    <!-- Stack -->
    <section class="section alt">
        <div class="container">
            <h2>Built on Proven Open Source</h2>
            <div class="stack-grid">
                <div class="stack-item">
                    <div class="stack-name">OpenObserve</div>
                    <div class="stack-desc">Logs, metrics, traces</div>
                </div>
                <div class="stack-item">
                    <div class="stack-name">Vector</div>
                    <div class="stack-desc">Data pipeline &amp; enrichment</div>
                </div>
                <div class="stack-item">
                    <div class="stack-name">Keep</div>
                    <div class="stack-desc">Alert correlation &amp; workflows</div>
                </div>
                <div class="stack-item">
                    <div class="stack-name">Qdrant</div>
                    <div class="stack-desc">Vector search &amp; knowledge base</div>
                </div>
                <div class="stack-item">
                    <div class="stack-name">NATS</div>
                    <div class="stack-desc">Messaging backbone</div>
                </div>
                <div class="stack-item">
                    <div class="stack-name">a10y engine</div>
                    <div class="stack-desc">Correlation &amp; closed loop</div>
                </div>
            </div>
        </div>
    </section>

    <!-- Bridging -->
    <section class="section">
        <div class="container">
            <h2>Bridging Telecom and IT</h2>
            <p>Telecom has decades of autonomous operation standards — TMF Autonomous Networks (L0–L5), ETSI ZSM, intent-based networking. IT has cloud-native observability, AIOps, and SRE. These worlds evolved in parallel. a10y brings them together.</p>
            <div class="links-bottom">
                <a href="/landscape">Explore the landscape →</a>
                <a href="/ooda">OODA × AI deep dive →</a>
                <a href="https://github.com/autonomously-io/awesome-autonomous-operation">awesome-autonomous-operation →</a>
            </div>
        </div>
    </section>
</Base>

<style>
    .hero {
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 90vh;
        text-align: center;
        padding: 4rem 2rem;
    }
    .hero-inner { max-width: 680px; }
    .logo {
        width: 340px;
        max-width: 85vw;
        margin-bottom: 0.5rem;
    }
    .expand {
        font-size: 1.2rem;
        color: #888;
        letter-spacing: 0.15em;
        margin-bottom: 2rem;
    }
    .tagline {
        font-size: 1.5rem;
        line-height: 1.7;
        color: #bbb;
        margin-bottom: 0.8rem;
    }
    .sub {
        font-size: 1.1rem;
        color: #666;
        margin-bottom: 3rem;
    }
    .links a {
        color: #4a9eff;
        text-decoration: none;
        margin: 0 1rem;
        font-size: 1.05rem;
    }
    .links a:hover { text-decoration: underline; }
    .github-star { margin-top: 2rem; }

    .section {
        padding: 5rem 2rem;
    }
    .section.alt {
        background: #0e0e0e;
    }
    .container {
        max-width: 800px;
        margin: 0 auto;
    }
    .section h2 {
        font-size: 1.6rem;
        font-weight: 600;
        color: #fff;
        margin-bottom: 1.5rem;
        border: none;
        padding: 0;
    }
    .pillars {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 1.5rem;
        margin: 1.5rem 0;
    }
    .pillar {
        border: 1px solid #222;
        border-radius: 8px;
        padding: 1.8rem;
    }
    .pillar h3 {
        font-size: 1.2rem;
        color: #fff;
        margin-bottom: 0.8rem;
        margin-top: 0;
    }
    .pillar p {
        margin-bottom: 0;
    }
    .center-note {
        text-align: center;
        margin-top: 1.5rem;
        color: #888;
        font-style: italic;
    }
    .stack-grid {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1rem;
    }
    .stack-item {
        border: 1px solid #222;
        border-radius: 8px;
        padding: 1.5rem;
        text-align: center;
    }
    .stack-name {
        font-size: 1.1rem;
        font-weight: 600;
        color: #fff;
        margin-bottom: 0.3rem;
    }
    .stack-desc {
        font-size: 0.95rem;
        color: #888;
    }
    .links-bottom {
        display: flex;
        gap: 2rem;
        margin-top: 2rem;
        flex-wrap: wrap;
    }
    .links-bottom a {
        color: #4a9eff;
        text-decoration: none;
        font-size: 1.05rem;
    }
    .links-bottom a:hover { text-decoration: underline; }

    @media (max-width: 600px) {
        .pillars { grid-template-columns: 1fr; }
        .stack-grid { grid-template-columns: 1fr 1fr; }
        .tagline { font-size: 1.2rem; }
        .links-bottom { flex-direction: column; gap: 1rem; }
    }
</style>
